# Copia este archivo como .env y llena los valores
# cp .env.example .env

# Base de datos PostgreSQL
# Local: postgresql://usuario:password@localhost:5432/football_scout
# Railway: te lo dan automático cuando creas la DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/football_scout

# API-Football (https://www.api-football.com)
# Plan gratuito: 100 requests/día — suficiente para empezar
API_FOOTBALL_KEY=tu_api_key_aqui
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# App config
APP_ENV=development
APP_PORT=8000
