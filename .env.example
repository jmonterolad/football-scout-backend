# Copy this file as .env and fill in your values
# cp .env.example .env

# PostgreSQL Database
# Local:      postgresql://username:password@localhost:5432/football_scout
# Supabase:   get it from your project's Connect → Session pooler
DATABASE_URL=postgresql://postgres:password@localhost:5432/football_scout

# API-Football (https://www.api-football.com)
# Free plan: 100 requests/day — enough to get started
# Get your key at: https://dashboard.api-football.com
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# App config
APP_ENV=development
APP_PORT=8000